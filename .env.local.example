# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://wodydpxedftpgesgjmrf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# ── PayPal ────────────────────────────────────────────────────────────────────
# Found at: developer.paypal.com → Apps & Credentials
# Use 'sandbox' for testing, 'live' for real money
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

# ── Paddle ────────────────────────────────────────────────────────────────────
# Found at: vendors.paddle.com → Developer Tools → Authentication
# Use 'sandbox' for testing, 'production' for real money
PADDLE_ENV=sandbox
PADDLE_API_KEY=your_paddle_api_key_here

# Price IDs from Paddle → Catalog → Prices
PADDLE_PRICE_1x1=pri_your_1x1_price_id
PADDLE_PRICE_10x10=pri_your_10x10_price_id
PADDLE_PRICE_100x100=pri_your_100x100_price_id
