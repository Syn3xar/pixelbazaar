'use client'
import { useState, useRef, useCallback } from 'react'
import Modal from './Modal'

type Props = { x: number; y: number; onClose: () => void; onSpecialName?: (name: string) => void }

const BLOCK_OPTIONS = [
  { label: '1×1', size: 1, pixels: 1, price: 1, description: '1 pixel — single color dot', pricePerPx: '$1.00/px' },
  { label: '10×10', size: 10, pixels: 100, price: 50, description: '100 pixels — small banner or icon', pricePerPx: '$0.50/px — 50% off' },
  { label: '100×100', size: 100, pixels: 10000, price: 1000, description: '10,000 pixels — full logo or image', pricePerPx: '$0.10/px — 90% off' },
]

const PALETTE = [
  '#000000','#ffffff','#FF3CAC','#784BA0','#2B86C5','#00C9FF',
  '#92FE9D','#FC5C7D','#FFD700','#FF6B6B','#4ECDC4','#f7971e',
  '#A8FF78','#B721FF','#08AEEA','#333333','#888888','#cccccc',
]

export default function BuyModal({ x, y, onClose, onSpecialName }: Props) {
  const [step, setStep] = useState<'choose' | 'design' | 'details'>('choose')
  const [blockOption, setBlockOption] = useState(BLOCK_OPTIONS[0])
  const [pixels, setPixels] = useState<string[]>([])
  const [activeColor, setActiveColor] = useState('#784BA0')
  const [painting, setPainting] = useState(false)
  const [tool, setTool] = useState<'paint' | 'fill'>('paint')
  const [form, setForm] = useState({ company: '', url: '', email: '' })
  const [loading, setLoading] = useState(false)

  function chooseBlock(opt: typeof BLOCK_OPTIONS[0]) {
    setBlockOption(opt)
    setPixels(Array(opt.pixels).fill('#111118'))
    setStep('design')
  }

  const paintPixel = useCallback((i: number) => {
    setPixels(prev => { const n = [...prev]; n[i] = activeColor; return n })
  }, [activeColor])

  function floodFill(startIdx: number, target: string, fill: string, grid: string[], size: number) {
    if (target === fill) return grid
    const next = [...grid], stack = [startIdx]
    while (stack.length) {
      const idx = stack.pop()!
      if (idx < 0 || idx >= next.length || next[idx] !== target) continue
      next[idx] = fill
      const row = Math.floor(idx / size), col = idx % size
      if (col > 0) stack.push(idx - 1)
      if (col < size - 1) stack.push(idx + 1)
      if (row > 0) stack.push(idx - size)
      if (row < size - 1) stack.push(idx + size)
    }
    return next
  }

  function handlePixelClick(i: number) {
    if (tool === 'fill') setPixels(prev => floodFill(i, prev[i], activeColor, prev, blockOption.size))
    else paintPixel(i)
  }

  function handleImageUpload(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0]
    if (!file) return
    const img = new Image()
    const url = URL.createObjectURL(file)
    img.onload = () => {
      const canvas = document.createElement('canvas')
      canvas.width = blockOption.size
      canvas.height = blockOption.size
      const ctx = canvas.getContext('2d')!
      ctx.drawImage(img, 0, 0, blockOption.size, blockOption.size)
      const data = ctx.getImageData(0, 0, blockOption.size, blockOption.size).data
      setPixels(Array.from({ length: blockOption.pixels }, (_, i) =>
        `rgb(${data[i*4]},${data[i*4+1]},${data[i*4+2]})`
      ))
      URL.revokeObjectURL(url)
    }
    img.src = url
  }

  async function handleSubmit() {
    if (!form.company.trim() || !form.url.trim() || !form.email.trim()) return alert('Please fill in all fields')
    setLoading(true)
    try {
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          x, y,
          company: form.company,
          url: form.url,
          email: form.email,
          blockSize: blockOption.size,
          pixelColors: pixels,
          price: blockOption.price,
        }),
      })
      const data = await res.json()
      if (data.url) window.location.href = data.url
      else { alert(data.error ?? 'Payment error'); setLoading(false) }
    } catch { alert('Payment error — please try again'); setLoading(false) }
  }

  const inp = {
    width: '100%', background: '#111118', border: '1px solid #2a2a3e',
    color: '#e0e0ff', padding: '10px 12px', fontFamily: "'Space Mono', monospace",
    fontSize: '13px', borderRadius: '2px', outline: 'none', boxSizing: 'border-box' as const,
  }

  // ── STEP 1: Choose block size ──────────────────────────────────────────────
  if (step === 'choose') return (
    <Modal title={`Buy Pixels at [${x}, ${y}]`} onClose={onClose}>
      <div style={{ color: '#666', fontSize: '11px', marginBottom: '20px', lineHeight: 1.6 }}>
        Choose your block size. Larger blocks give you a bigger discount and let you display a full pixelated logo or image.
      </div>

      {BLOCK_OPTIONS.map((opt, idx) => (
        <div key={opt.label} onClick={() => chooseBlock(opt)} style={{
          background: '#0f0f1a',
          border: `1px solid ${idx === 2 ? '#FFD700' : '#2a2a3e'}`,
          borderRadius: '2px', padding: '16px 20px', marginBottom: '10px',
          cursor: 'pointer', display: 'flex', justifyContent: 'space-between', alignItems: 'center',
          position: 'relative', overflow: 'hidden',
        }}
          onMouseEnter={e => (e.currentTarget.style.borderColor = '#784BA0')}
          onMouseLeave={e => (e.currentTarget.style.borderColor = idx === 2 ? '#FFD700' : '#2a2a3e')}
        >
          {idx === 2 && (
            <div style={{ position: 'absolute', top: 0, right: 0, background: '#FFD700', color: '#000', fontSize: '9px', padding: '3px 8px', fontWeight: 'bold', letterSpacing: '0.1em' }}>
              BEST VALUE
            </div>
          )}
          <div>
            <div style={{ color: '#e0e0ff', fontSize: '15px', fontWeight: 'bold', marginBottom: '4px' }}>
              {opt.label} block
            </div>
            <div style={{ color: '#555', fontSize: '11px', marginBottom: '4px' }}>{opt.description}</div>
            <div style={{ color: idx === 0 ? '#555' : '#92FE9D', fontSize: '10px' }}>{opt.pricePerPx}</div>
          </div>
          <div style={{ textAlign: 'right', flexShrink: 0, marginLeft: '16px' }}>
            <div style={{ color: '#FFD700', fontSize: '22px', fontWeight: 'bold' }}>${opt.price}</div>
            <div style={{ color: '#555', fontSize: '10px' }}>{opt.pixels.toLocaleString()} pixels</div>
          </div>
        </div>
      ))}

      <div style={{ color: '#444', fontSize: '10px', marginTop: '12px', textAlign: 'center' }}>
        Platform keeps 10% • Worldwide PayPal accepted
      </div>
    </Modal>
  )

  // ── STEP 2: Design pixels ──────────────────────────────────────────────────
  if (step === 'design') {
    // Cell size: 1px→120, 10px→26, 100px→4
    const cellSize = blockOption.size === 1 ? 120 : blockOption.size === 10 ? 26 : 4
    const gridPx = cellSize * blockOption.size

    return (
      <Modal title={`Design your ${blockOption.label} block`} onClose={onClose}>
        {/* Toolbar */}
        <div style={{ display: 'flex', gap: '6px', marginBottom: '12px', flexWrap: 'wrap', alignItems: 'center' }}>
          {[{ id: 'paint', label: '✏️ Paint' }, { id: 'fill', label: '🪣 Fill' }].map(t => (
            <button key={t.id} onClick={() => setTool(t.id as 'paint' | 'fill')} style={{
              padding: '5px 10px', fontSize: '11px', cursor: 'pointer', borderRadius: '2px',
              background: tool === t.id ? '#784BA0' : '#111118',
              color: tool === t.id ? '#fff' : '#666',
              border: `1px solid ${tool === t.id ? '#784BA0' : '#2a2a3e'}`,
              fontFamily: 'inherit',
            }}>{t.label}</button>
          ))}
          <div style={{ flex: 1 }} />
          <label style={{ padding: '5px 10px', fontSize: '11px', cursor: 'pointer', borderRadius: '2px', background: '#111118', color: '#4ECDC4', border: '1px solid #4ECDC4', fontFamily: 'inherit', whiteSpace: 'nowrap' }}>
            🖼 Upload Image / Logo
            <input type="file" accept="image/*" onChange={handleImageUpload} style={{ display: 'none' }} />
          </label>
          <button onClick={() => setPixels(Array(blockOption.pixels).fill('#111118'))} style={{ padding: '5px 10px', fontSize: '11px', cursor: 'pointer', borderRadius: '2px', background: '#111118', color: '#666', border: '1px solid #2a2a3e', fontFamily: 'inherit' }}>
            🗑 Clear
          </button>
        </div>

        {/* Color palette */}
        <div style={{ marginBottom: '12px' }}>
          <div style={{ fontSize: '10px', color: '#555', marginBottom: '6px', letterSpacing: '0.1em', textTransform: 'uppercase' }}>Active Color</div>
          <div style={{ display: 'flex', gap: '4px', flexWrap: 'wrap', alignItems: 'center' }}>
            {PALETTE.map(c => (
              <div key={c} onClick={() => setActiveColor(c)} style={{
                width: '22px', height: '22px', background: c, cursor: 'pointer',
                borderRadius: '2px', flexShrink: 0,
                border: activeColor === c ? '2px solid #fff' : '1px solid #333',
              }} />
            ))}
            <input type="color" value={activeColor} onChange={e => setActiveColor(e.target.value)}
              style={{ width: '28px', height: '22px', cursor: 'pointer', border: '1px solid #333', borderRadius: '2px', background: 'none', padding: 0 }} />
            <span style={{ color: '#444', fontSize: '10px' }}>custom</span>
          </div>
        </div>

        {/* Pixel grid */}
        <div style={{ display: 'flex', justifyContent: 'center', marginBottom: '12px', overflowX: 'auto' }}>
          <div>
            {blockOption.size === 100 && (
              <div style={{ color: '#555', fontSize: '10px', textAlign: 'center', marginBottom: '6px' }}>
                Tip: Upload your logo above — it will fill all 10,000 pixels automatically!
              </div>
            )}
            <div
              style={{
                display: 'grid',
                gridTemplateColumns: `repeat(${blockOption.size}, ${cellSize}px)`,
                border: '1px solid #2a2a3e',
                cursor: tool === 'fill' ? 'crosshair' : 'cell',
                userSelect: 'none',
                width: `${gridPx}px`,
                height: `${gridPx}px`,
              }}
              onMouseLeave={() => setPainting(false)}
            >
              {pixels.map((color, i) => (
                <div
                  key={i}
                  style={{
                    width: cellSize, height: cellSize, background: color,
                    border: cellSize >= 8 ? '0.5px solid rgba(255,255,255,0.04)' : 'none',
                    boxSizing: 'border-box',
                  }}
                  onMouseDown={() => { setPainting(true); handlePixelClick(i) }}
                  onMouseEnter={() => { if (painting && tool === 'paint') paintPixel(i) }}
                  onMouseUp={() => setPainting(false)}
                />
              ))}
            </div>
          </div>
        </div>

        <div style={{ display: 'flex', gap: '10px' }}>
          <button onClick={() => setStep('choose')} style={{ flex: 1, background: 'transparent', border: '1px solid #333', color: '#888', padding: '10px', cursor: 'pointer', fontFamily: 'inherit', fontSize: '12px', borderRadius: '2px' }}>
            ← Back
          </button>
          <button onClick={() => setStep('details')} style={{ flex: 2, background: '#784BA0', color: '#fff', border: 'none', padding: '10px', cursor: 'pointer', fontFamily: 'inherit', fontSize: '12px', letterSpacing: '0.08em', borderRadius: '2px' }}>
            Next — Add Details →
          </button>
        </div>
      </Modal>
    )
  }

  // ── STEP 3: Details & pay ──────────────────────────────────────────────────
  const previewCell = blockOption.size === 1 ? 80 : blockOption.size === 10 ? 14 : 2

  return (
    <Modal title="Complete your purchase" onClose={onClose}>
      {/* Preview */}
      <div style={{ display: 'flex', justifyContent: 'center', marginBottom: '20px' }}>
        <div>
          <div style={{ fontSize: '10px', color: '#555', textAlign: 'center', marginBottom: '6px', letterSpacing: '0.1em' }}>YOUR BLOCK PREVIEW</div>
          <div style={{
            display: 'grid',
            gridTemplateColumns: `repeat(${blockOption.size}, ${previewCell}px)`,
            border: '1px solid #2a2a3e', borderRadius: '2px', overflow: 'hidden',
            width: `${previewCell * blockOption.size}px`,
            height: `${previewCell * blockOption.size}px`,
          }}>
            {pixels.map((color, i) => (
              <div key={i} style={{ width: previewCell, height: previewCell, background: color }} />
            ))}
          </div>
        </div>
      </div>

      {[
        { label: 'Your Email', key: 'email', type: 'email', ph: 'you@company.com' },
        { label: 'Company Name', key: 'company', type: 'text', ph: 'Acme Corp' },
        { label: 'Website URL (clickable on the board)', key: 'url', type: 'text', ph: 'https://yoursite.com' },
      ].map(({ label, key, type, ph }) => (
        <div key={key} style={{ marginBottom: '14px' }}>
          <label style={{ display: 'block', fontSize: '10px', letterSpacing: '0.1em', color: '#666', marginBottom: '6px', textTransform: 'uppercase' }}>{label}</label>
          <input type={type} value={(form as any)[key]} onChange={e => setForm(f => ({ ...f, [key]: e.target.value }))} placeholder={ph} style={inp} />
        </div>
      ))}

      <div style={{ background: '#0f0f1a', border: '1px solid #1a1a2e', borderRadius: '2px', padding: '14px', marginBottom: '20px' }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: '11px', color: '#555', marginBottom: '6px' }}>
          <span>{blockOption.label} block — {blockOption.pixels.toLocaleString()} pixels</span>
          <span style={{ color: '#e0e0ff' }}>${blockOption.price}.00</span>
        </div>
        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: '11px', color: '#555' }}>
          <span>Platform fee (10%)</span>
          <span style={{ color: '#FF6B6B' }}>included</span>
        </div>
        <div style={{ borderTop: '1px solid #1a1a2e', marginTop: '8px', paddingTop: '8px', display: 'flex', justifyContent: 'space-between', fontSize: '13px' }}>
          <span style={{ color: '#e0e0ff' }}>Total Due</span>
          <span style={{ color: '#FFD700', fontSize: '18px' }}>${blockOption.price}.00</span>
        </div>
      </div>

      <div style={{ display: 'flex', gap: '10px' }}>
        <button onClick={() => setStep('design')} style={{ flex: 1, background: 'transparent', border: '1px solid #333', color: '#888', padding: '10px', cursor: 'pointer', fontFamily: 'inherit', fontSize: '12px', borderRadius: '2px' }}>
          ← Back
        </button>
        <button onClick={handleSubmit} disabled={loading} style={{ flex: 2, background: loading ? '#444' : '#784BA0', color: '#fff', border: 'none', padding: '10px', cursor: 'pointer', fontFamily: 'inherit', fontSize: '12px', letterSpacing: '0.08em', borderRadius: '2px' }}>
          {loading ? 'Redirecting...' : `Pay $${blockOption.price} with PayPal →`}
        </button>
      </div>
    </Modal>
  )
}
